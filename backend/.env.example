# Copy this file to backend/.env and fill in your real secrets locally.
# Do NOT commit backend/.env to source control.

# Database (example for remote Postgres)
# DATABASE_URL=postgresql+psycopg2://username:password@host:5432/studyplanner

# App secret
# SECRET_KEY=replace-with-a-long-random-secret

# Provider selection: ollama, openai, gemini, anthropic
# DEFAULT_PROVIDER=openai
# DEFAULT_MODEL=gpt-4.1-mini

# OpenAI API key (if using OpenAI)
# OPENAI_API_KEY=sk-...

# Ollama settings (if using local Ollama service via docker-compose)
# OLLAMA_BASE_URL=http://ollama:11434
